{
  "name": "zombie-squad-run-ios-webwrap",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor-ready wrapper scaffold for Zombie Squad Run",
  "scripts": {
    "prepare:web": "node tools/prepare-web.js",
    "release:prep": "node tools/prepare-web.js && node tools/make-release-bundle.js",
    "validate:release": "node tools/validate-release.js",
    "preflight": "node tools/validate-release.js && node tools/print-next-steps.js",
    "release:check": "node tools/full-release-check.js",
    "cap:init:notes": "node tools/print-next-steps.js"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2"
  }
}
